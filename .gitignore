# ==========================================
# OS / editor junk
# ==========================================
.DS_Store
Thumbs.db

.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Logs / temp / backups
# ==========================================
*.log
*.tmp
*.temp
*.bak
*.old
*.orig
*~

tmp/
temp/
cache/

# ==========================================
# Python / Node tooling (if you add scripts)
# ==========================================
__pycache__/
*.pyc
.venv/
venv/
node_modules/
dist/
build/

# ==========================================
# Environment / secrets
# ==========================================
.env
.env.local
.env.*
!.env.example

# ==========================================
# 3D printing machine-generated outputs
# Usually regenerate these from project/source
# ==========================================
*.gcode
*.bgcode
*.x3g
*.gx
*.ufp

# Bambu/Orca sliced export variants
*.gcode.3mf
*.bgcode.3mf

# ==========================================
# Autosaves / recovery / scratch exports
# ==========================================
*.autosave
*.backup
*.bak3mf

exports/tmp/
exports/test/
plates/tmp/

# ==========================================
# Camera / timelapse / render junk
# Keep curated photos elsewhere if desired
# ==========================================
timelapse/
videos/output/
renders/output/
renders/cache/

# ==========================================
# Compressed archives
# ==========================================
*.zip
*.7z
*.rar